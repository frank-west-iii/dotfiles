[alias]
  aa = add --all
  an = add -N .
  b = branch
  co = checkout
  cleanup = !git remote prune origin && git gc
  cleanup-all = !git remote prune origin && git gc && git clean -df && git stash clear
  lg = log --graph --pretty=format:'%Cred%h%Creset -%C(yellow)%d%Creset %s %Cgreen(%cr)%Creset' --abbrev-commit --date=relative
  rhm = !git checkout master && git fetch && git reset --hard origin/master
  st = status
  step = !git aa && git commit -m 'Refactor step'
  dm = !git checkout master && git branch --merged | grep -v master | xargs git branch -d
  rho = !git fetch && git reset --hard origin/$(git rev-parse --abbrev-ref HEAD)
  cm = !git fetch  && git branch --merged | grep -v master | grep -v staging | grep -v develop | xargs git branch -d && git remote prune origin
  pf = push --force-with-lease
  poh = push -u origin HEAD
  bd = !git for-each-ref --sort='-committerdate' --format='%(committerdate)%09%(refname)' refs/heads | sed -e 's-refs/heads/--'
  startfeature = flow feature start
  finishfeature = flow feature finish
  publishfeature = flow feature publish
  g = guess
  wip = "!f() { git add --all && git commit -n -m \"✏ $*\"; }; f"
  update = !git checkout develop && git fetch && git reset --hard origin/develop && git co - && git rebase develop
  squash = !git fetch && git rebase origin/develop && git reset --soft origin/develop && git commit
  amino = !git add --all && git commit --amend --no-edit
  tg = log master.. --pretty=format:"%s" --reverse --no-merges
  today = !git log --all --since=midnight --author=\"$(git config user.name)\" --oneline
  yesterday = !git log --all --since="day.before.yesterday.midnight" --until=midnight --author=\"$(git config user.name)\" --oneline
  week = !git log --all --since=\"1 friday ago\" --author=\"$(git config user.name)\" --oneline
  lastweek = !git log --all --since=\"2 friday ago\" --author=\"$(git config user.name)\" --oneline

[color]
  diff = auto
  status = auto
  branch = auto

[color "diff"]
  meta = yellow

[core]
  excludesfile = ~/.gitignore
  editor = nvim
[apply]
  whitespace = nowarn

[commit]
  template = ~/.gitmessage

[user]
  name = Frank West
  email = frank.west@waybetter.com
[push]
	default = simple
[gitflow "feature.finish"]
  push = true
  keep = true
[gitflow "bugfix.finish"]
  push = true
  keep = true
[gitflow "hotfix.finish"]
  push = true
  keep = true
[gitflow "release.start"]
  allowdirty = true
[gitflow "release.finish"]
  push = true
  keep = true
